# Base Sepolia JSON-RPC endpoint. The public endpoint is used if omitted.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer private key, including the 0x prefix. Never commit a funded key.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# API key used to verify the contract on BaseScan.
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# Existing deployment records are protected by default. Set true only for an intentional replacement.
ALLOW_DEPLOYMENT_OVERWRITE=false
