{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "mocha"],
    "outDir": "dist"
  },
  "include": ["hardhat.config.ts", "scripts", "test"],
  "exclude": ["node_modules"]
}
